---
// src/layouts/DashboardLayout.astro
// Apple UI inspired minimalist layout wrapper
import '../styles/global.css';

interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage } = Astro.props;

const nav = [
  {
    label: 'Bridge',
    items: [
      { href: '/',            label: 'Overview',    icon: 'grid',      id: 'overview' },
      { href: '/containers',  label: 'Containers',  icon: 'box',       id: 'containers' },
      { href: '/logs',        label: 'Logs Console', icon: 'scroll',    id: 'logs' },
    ],
  },
  {
    label: 'Apps',
    items: [
      { href: '/notes',       label: 'Notes',       icon: 'notes',     id: 'notes' },
    ],
  },
];

const icons: Record<string, string> = {
  grid: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 3a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1H3ZM3 11a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1H3ZM11 3a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1h-4ZM11 11a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1h-4Z" clip-rule="evenodd"/></svg>`,
  box: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M2 3a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3Z"/></svg>`,
  scroll: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm12 1a1 1 0 100 2h1a1 1 0 100-2h-1zm-1 4a1 1 0 011-1h1a1 1 0 110 2h-1a1 1 0 01-1-1zm-9-3a1 1 0 011-1h5a1 1 0 110 2H6a1 1 0 01-1-1zm1 4a1 1 0 100 2h5a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>`,
  notes: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"/></svg>`,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Server Dashboard – Command Cockpit Homelab Control Center" />
    <title>{title} · Server Dashboard</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="app-shell">

      <!-- ── Sidebar navigation ─────────────────────────────────────────── -->
      <aside class="sidebar">
        <div class="sidebar-logo">
          <div class="sidebar-logo-icon">T</div>
          <div>
            <div class="sidebar-logo-text">Server Dashboard</div>
            <div class="sidebar-logo-sub">Homelab Control</div>
          </div>
        </div>

        <nav class="sidebar-nav">
          {nav.map(section => (
            <>
              <div class="nav-section-label">{section.label}</div>
              {section.items.map(item => (
                <a
                  href={item.href}
                  class={`nav-link ${activePage === item.id ? 'active' : ''}`}
                >
                  <span set:html={icons[item.icon]} />
                  {item.label}
                </a>
              ))}
            </>
          ))}
        </nav>

        <div class="sidebar-footer">
          <div>Server Dashboard v1.0.0</div>
        </div>
      </aside>

      <!-- ── Topbar ──────────────────────────────────────────────────────── -->
      <header class="topbar">
        <h1 class="topbar-title">{title}</h1>

        <!-- Static, clean Apple status bar metrics -->
        <div class="topbar-status-bar">
          <div class="status-bar-item">
            <span class="label">CPU</span>
            <span id="ticker-cpu" style="font-weight: 600;">—</span>
          </div>
          <div class="status-bar-item">
            <span class="label">RAM</span>
            <span id="ticker-ram" style="font-weight: 600;">—</span>
          </div>
          <div class="status-bar-item">
            <span class="label">Ping</span>
            <span id="ticker-ping" style="font-weight: 600;">—</span>
          </div>
        </div>

        <div class="topbar-actions">
          <span id="connection-status" class="hud-badge error">Connecting…</span>
          <button class="btn-deck btn-ghost" id="refresh-btn" style="padding:6px 12px; font-size:12px;">
            Sync
          </button>
        </div>
      </header>

      <!-- ── Main Viewport ──────────────────────────────────────────────── -->
      <main class="main-content">
        <slot />
      </main>
      
      <!-- ── Mobile bottom Tabbar ───────────────────────────────────────── -->
      <nav class="mobile-nav-bar">
        <a href="/" class={`mobile-nav-item ${activePage === 'overview' ? 'active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/></svg>
          <span>Overview</span>
        </a>
        <a href="/containers" class={`mobile-nav-item ${activePage === 'containers' ? 'active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path d="M7 3a1 1 0 00-1 1v12a1 1 0 001 1h6a1 1 0 001-1V4a1 1 0 00-1-1H7z"/></svg>
          <span>Containers</span>
        </a>
        <a href="/logs" class={`mobile-nav-item ${activePage === 'logs' ? 'active' : ''}`}>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm12 1a1 1 0 100 2h1a1 1 0 100-2h-1zm-1 4a1 1 0 011-1h1a1 1 0 110 2h-1a1 1 0 01-1-1zm-9-3a1 1 0 011-1h5a1 1 0 110 2H6a1 1 0 01-1-1zm1 4a1 1 0 100 2h5a1 1 0 100-2H6z" clip-rule="evenodd"/></svg>
          <span>Logs</span>
        </a>
      </nav>

    </div>

    <script>
      import { api } from '../lib/api.ts';

      async function checkHealthAndStats() {
        const el = document.getElementById('connection-status');
        const cpuEl = document.getElementById('ticker-cpu');
        const ramEl = document.getElementById('ticker-ram');
        const pingEl = document.getElementById('ticker-ping');

        try {
          const sys = await api.system.info();
          
          if (el) {
            el.textContent = 'Online';
            el.className = 'hud-badge running';
          }

          if (cpuEl) cpuEl.textContent = `${sys.cpu.loadPercent}%`;
          if (ramEl) ramEl.textContent = `${sys.memory.usedPercent}%`;
          if (pingEl) pingEl.textContent = sys.pingLatency !== null ? `${sys.pingLatency}ms` : '—';
        } catch {
          if (el) {
            el.textContent = 'Offline';
            el.className = 'hud-badge error';
          }
          if (cpuEl) cpuEl.textContent = '—';
          if (ramEl) ramEl.textContent = '—';
          if (pingEl) pingEl.textContent = '—';
        }
      }

      checkHealthAndStats();
      setInterval(checkHealthAndStats, 5000);

      document.getElementById('refresh-btn')?.addEventListener('click', () => {
        window.location.reload();
      });
    </script>
  </body>
</html>
