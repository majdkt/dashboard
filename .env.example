# Teze Dashboard – environment variable reference
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# ── API Connection ────────────────────────────────────────────────────────────
# URL the *browser* uses to reach the Teze API.
# For local dev this is usually http://localhost:3001.
# When deployed on a homelab server, use the server's LAN IP or Tailscale hostname.
PUBLIC_API_URL=http://localhost:3001
# PUBLIC_API_URL=http://192.168.1.100:3001

# ── Default Quick-Link Portals ────────────────────────────────────────────────
# Pre-seeded bookmark URLs shown on the Overview dashboard.
# Set to empty string to hide the default; users can always add custom ones.
PUBLIC_PORTAINER_URL=http://localhost:9000
PUBLIC_PLEX_URL=http://localhost:32400
PUBLIC_PIHOLE_URL=http://localhost:80/admin
PUBLIC_HOMEASSISTANT_URL=http://localhost:8123
